{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "subscriptionStatus": { "type": "string", "enum": ["free", "monthly", "yearly"], "description": "Current subscription status" },
        "subscriptionExpiry": { "type": "string", "format": "date-time", "description": "Subscription expiration date" },
        "createdAt": { "type": "string", "format": "date-time", "description": "User creation date" }
      },
      "required": ["uid", "email", "subscriptionStatus"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A saved recipe generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique recipe ID" },
        "userId": { "type": "string", "description": "Owner UID" },
        "dishName": { "type": "string", "description": "Name of the dish" },
        "ingredients": { "type": "array", "items": { "type": "string" }, "description": "List of ingredients" },
        "instructions": { "type": "array", "items": { "type": "string" }, "description": "Step-by-step instructions" },
        "cookingTime": { "type": "string", "description": "Estimated cooking time" },
        "detectedIngredients": { "type": "array", "items": { "type": "string" }, "description": "Ingredients detected from image" },
        "imageUrl": { "type": "string", "description": "URL of the uploaded image (if stored)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Generation date" }
      },
      "required": ["userId", "dishName", "ingredients", "instructions"]
    },
    "HistoryItem": {
      "title": "HistoryItem",
      "description": "A record of an image upload and analysis",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique history ID" },
        "userId": { "type": "string", "description": "User UID" },
        "detectedIngredients": { "type": "array", "items": { "type": "string" }, "description": "Ingredients detected from image" },
        "imageUrl": { "type": "string", "description": "Base64 or URL of the image" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload date" }
      },
      "required": ["userId", "detectedIngredients", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and subscription data"
    },
    "/users/{userId}/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Saved recipes for a user"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "Upload history for a user"
    }
  }
}
